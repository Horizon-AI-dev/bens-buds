# Local-only secret fallback (do not use in production)
DISCORD_BOT_TOKEN=

# Production secret reference (Secret Manager secret version resource name)
# Example: projects/my-project/secrets/discord-bot-token/versions/latest
DISCORD_BOT_TOKEN_SECRET=

# Optional service account JSON payload for Vertex auth in local/dev.
GCP_SERVICE_ACCOUNT_JSON=

# Optional Secret Manager version name that stores service account JSON payload.
# Example: projects/my-project/secrets/gcp-service-account-json/versions/latest
GCP_SERVICE_ACCOUNT_JSON_SECRET=

# Non-secret runtime config
LOG_LEVEL=info
PROMPT_FILE_PATH=prompts/system/alt-character-coach.txt
PORT=8080
GCP_PROJECT_ID=bens-buds
GCP_LOCATION=us-central1
GEMINI_MODEL=gemini-3.0-flash
DISCORD_APPLICATION_ID=1480034248902574200
